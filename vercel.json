{
    "version": 2,
    "outputDirectory": "dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/dist/index.html"
        }
    ]
}